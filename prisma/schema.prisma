generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  firstName         String
  lastName          String
  email             String    @unique
  password          String    @default("")
  isBlocked         Boolean   @default(false)
  registeredAt      DateTime  @default(now())
  emailVerified     Boolean   @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  isPublished       Boolean   @default(true)
  subscriptionStatus String   @default("free")
  subscriptionId     String?
  customerId         String?
  currentPeriodEnd   DateTime?
  isFreeAccess       Boolean   @default(false)
  isPaid             Boolean   @default(false)
  paypalTxId         String?
  customDomain       String?   @unique

  sections     Section[]
  contentItems ContentItem[]
  siteContent  SiteContent?
  navLinks     NavLink[]
  contactLinks ContactLink[]
  theme        Theme?
  resume       Resume?
}

model Section {
  id              String   @id @default(cuid())
  userId          String
  name            String
  slug            String
  label           String
  subtitle        String   @default("")
  backgroundColor String   @default("#181818")
  order           Int      @default(0)

  // C-1: Section name styling
  nameColor       String @default("")
  nameFont        String @default("")
  nameWeight      String @default("")

  // C-1: Section label styling
  labelColor      String @default("")
  labelFont       String @default("")
  labelWeight     String @default("")

  // C-1: Section subtitle styling
  subtitleColor   String @default("")
  subtitleFont    String @default("")
  subtitleWeight  String @default("")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItems ContentItem[]

  @@unique([userId, slug])
}

model ContentItem {
  id            String  @id @default(cuid())
  userId        String
  sectionId     String
  slug          String  @default("")
  contentType   String  @default("project")
  title         String
  description   String  @default("")
  longDescription String @default("")
  tags          String  @default("")
  coverImage    String  @default("")
  coverImageDesc String @default("")
  image1        String  @default("")
  image1Desc    String  @default("")
  image2        String  @default("")
  image2Desc    String  @default("")
  image3        String  @default("")
  image3Desc    String  @default("")
  liveUrl       String  @default("")
  repoUrl       String  @default("")
  videoUrl      String  @default("")
  videoDesc     String  @default("")
  codeContent   String  @default("")
  codeLanguage  String  @default("")
  modelUrl      String  @default("")
  order         Int     @default(0)

  // Card background color
  cardBg          String @default("")

  // P-1: Title styling
  titleColor      String @default("")
  titleFont       String @default("")
  titleWeight     String @default("")

  // P-1: Description styling
  descColor       String @default("")
  descFont        String @default("")
  descWeight      String @default("")

  // P-1: Tag styling
  tagBg           String @default("")
  tagColor        String @default("")
  tagFont         String @default("")
  tagWeight       String @default("")

  // Long description styling
  longDescColor   String @default("")
  longDescFont    String @default("")
  longDescWeight  String @default("")

  // Image description styling
  imgDescColor    String @default("")
  imgDescFont     String @default("")
  imgDescWeight   String @default("")

  // P-2: Live URL button styling
  liveBtnText     String @default("")
  liveBtnBg       String @default("")
  liveBtnColor    String @default("")
  liveBtnFont     String @default("")
  liveBtnWeight   String @default("")

  // P-2: Repo URL button styling
  repoBtnText     String @default("")
  repoBtnBg       String @default("")
  repoBtnColor    String @default("")
  repoBtnFont     String @default("")
  repoBtnWeight   String @default("")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
}

model SiteContent {
  id              String   @id @default(cuid())
  userId          String   @unique
  siteTitle       String   @default("")
  logoText        String   @default("")
  headline        String   @default("")
  subtext         String   @default("")
  ctaLabel1       String   @default("")
  ctaTarget1      String   @default("")
  ctaLabel2       String   @default("")
  ctaTarget2      String   @default("")
  aboutText       String   @default("")
  skills          String   @default("")
  contactTitle    String   @default("")
  contactSubtitle String   @default("")
  footerText      String   @default("")
  loadingHeading        String   @default("")
  loadingSubtitle       String   @default("")
  loadingScreenEnabled  Boolean  @default(true)
  logoUrl         String   @default("")
  useLogoImage    Boolean  @default(false)

  // N-1: Sticky navbar background
  navScrollBg       String @default("")

  // Hamburger menu icon color (mobile)
  hamburgerColor    String @default("")

  // N-3: Brand text styling
  logoTextColor     String @default("")
  logoTextFont      String @default("")
  logoTextWeight    String @default("")

  // H-1: Headline styling
  headlineColor     String @default("")
  headlineFont      String @default("")
  headlineWeight    String @default("")

  // H-1: Subtext styling
  subtextColor      String @default("")
  subtextFont       String @default("")
  subtextWeight     String @default("")

  // H-2: Primary CTA styling
  ctaBg1            String @default("")
  ctaTextColor1     String @default("")
  ctaFont1          String @default("")
  ctaWeight1        String @default("")

  // H-2: Secondary CTA styling
  ctaBg2            String @default("")
  ctaTextColor2     String @default("")
  ctaFont2          String @default("")
  ctaWeight2        String @default("")

  // About section heading
  aboutHeading      String @default("")
  aboutHeadingColor String @default("")
  aboutHeadingFont  String @default("")
  aboutHeadingWeight String @default("")

  // A-1: About text styling
  aboutTextColor    String @default("")
  aboutTextFont     String @default("")
  aboutTextWeight   String @default("")

  // A-2: Skills tag styling
  skillTagBg        String @default("")
  skillTagColor     String @default("")
  skillTagFont      String @default("")
  skillTagWeight    String @default("")

  // CT-1: Contact title styling
  contactTitleColor    String @default("")
  contactTitleFont     String @default("")
  contactTitleWeight   String @default("")

  // CT-1: Contact subtitle styling
  contactSubColor      String @default("")
  contactSubFont       String @default("")
  contactSubWeight     String @default("")

  // F-1: Footer text styling
  footerTextColor   String @default("")
  footerTextFont    String @default("")
  footerTextWeight  String @default("")

  // L-1: Loading heading styling
  loadingHeadingColor  String @default("")
  loadingHeadingFont   String @default("")
  loadingHeadingWeight String @default("")

  // L-1: Loading subtitle styling
  loadingSubColor      String @default("")
  loadingSubFont       String @default("")
  loadingSubWeight     String @default("")

  // L-2: Loading screen background
  loadingBgColor       String @default("")

  // L-3: Loading screen duration (seconds)
  loadingDuration      Float  @default(2.5)

  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PricingConfig {
  id          String   @id @default(cuid())
  heading     String   @default("Simple, *Honest* Pricing")
  subtitle    String   @default("No subscriptions. No surprises.")
  price       String   @default("$5")
  period      String   @default("one-time")
  tagline     String   @default("Pay once. Lifetime access. No recurring charges.")
  features    String   @default("Live public portfolio\nResume builder & downloads\nCustom themes & colors\nBuilt-in analytics\nContact links & nav\nLifetime access")
  ctaLabel    String   @default("Get Started")

  // Styling: Heading
  headingColor       String @default("#ffffff")
  headingFont        String @default("")
  headingWeight      String @default("700")
  headingAccentColor String @default("#70E844")

  // Styling: Subtitle
  subtitleColor  String @default("#9ca3af")
  subtitleFont   String @default("")
  subtitleWeight String @default("400")

  // Styling: Price
  priceColor  String @default("#ffffff")
  priceFont   String @default("")
  priceWeight String @default("700")

  // Styling: Period
  periodColor  String @default("#9ca3af")
  periodFont   String @default("")
  periodWeight String @default("400")

  // Styling: Tagline
  taglineColor  String @default("#9ca3af")
  taglineFont   String @default("")
  taglineWeight String @default("400")

  // Styling: Features
  featuresColor  String @default("#e5e7eb")
  featuresFont   String @default("")
  featuresWeight String @default("400")
  featuresMarkColor String @default("#70E844")

  // Styling: Card
  cardBgColor   String @default("#181818")

  // Styling: CTA Button
  ctaColor      String @default("#131313")
  ctaFont       String @default("")
  ctaWeight     String @default("700")
  ctaBgColor    String @default("#70E844")

  updatedAt   DateTime @updatedAt
}

model NavLink {
  id     String @id @default(cuid())
  userId String
  label  String
  href   String
  order  Int    @default(0)

  // N-4: Link label styling
  labelColor  String @default("")
  labelFont   String @default("")
  labelWeight String @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactLink {
  id       String @id @default(cuid())
  userId   String
  platform String
  url      String
  order    Int    @default(0)

  // CT-2: Icon & background color
  iconBgColor   String @default("")
  iconColor     String @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Theme {
  id             String @id @default(cuid())
  userId         String @unique
  accentColor    String @default("#70E844")
  backgroundColor String @default("#131313")
  surfaceColor   String @default("#181818")
  textColor      String @default("#fafafa")
  dangerColor    String @default("#FE454E")
  cursorColor    String @default("#70E844")
  bodyFont       String @default("Inter")
  headingFont    String @default("Syne")
  faviconUrl     String @default("")
  webclipUrl     String @default("")
  logoUrl        String @default("")
  coverImage1    String @default("")
  coverImage2    String @default("")
  coverImage3    String @default("")
  coverImage4    String @default("")
  websiteTitle   String @default("")
  gridColor      String @default("rgba(255,255,255,0.03)")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id              String   @id @default(cuid())
  userId          String   @unique
  templateId      String   @default("classic")
  fullName        String   @default("")
  jobTitle        String   @default("")
  email           String   @default("")
  phone           String   @default("")
  location        String   @default("")
  website         String   @default("")
  summary         String   @default("")
  photoUrl        String   @default("")
  accentColor     String   @default("")
  showSummary     Boolean  @default(true)
  showExperience  Boolean  @default(true)
  showEducation   Boolean  @default(true)
  showSkills      Boolean  @default(true)
  showOnPortfolio Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences ResumeExperience[]
  educations  ResumeEducation[]
  skills      ResumeSkill[]
}

model ResumeExperience {
  id          String  @id @default(cuid())
  resumeId    String
  company     String  @default("")
  position    String  @default("")
  location    String  @default("")
  startDate   String  @default("")
  endDate     String  @default("")
  description String  @default("")
  order       Int     @default(0)

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ResumeEducation {
  id          String  @id @default(cuid())
  resumeId    String
  school      String  @default("")
  degree      String  @default("")
  field       String  @default("")
  startDate   String  @default("")
  endDate     String  @default("")
  description String  @default("")
  order       Int     @default(0)

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ResumeSkill {
  id       String @id @default(cuid())
  resumeId String
  name     String @default("")
  level    String @default("")
  order    Int    @default(0)

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model PageView {
  id        String   @id @default(cuid())
  username  String
  timestamp DateTime @default(now())
  referrer  String?

  @@index([username])
  @@index([username, timestamp])
}

model ContactClick {
  id          String   @id @default(cuid())
  username    String
  contactType String
  timestamp   DateTime @default(now())

  @@index([username])
}
