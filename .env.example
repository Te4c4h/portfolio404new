# Database
DATABASE_URL="postgresql://user:password@localhost:5432/portfolio404"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Admin
ADMIN_EMAIL="te4c4h@gmail.com"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (email verification)
RESEND_API_KEY=""

# LemonSqueezy (subscription payments)
# Set to "true" once LemonSqueezy account is verified to enable payment UI
NEXT_PUBLIC_LEMONSQUEEZY_ENABLED=false
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_VARIANT_ID=""

# File uploads (local storage)
# Directory where uploaded images are stored on the server
UPLOAD_DIR="/var/uploads/portfolio404"
